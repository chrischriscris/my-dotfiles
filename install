#!/usr/bin/env bash
set -euo pipefail

repo_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v stow >/dev/null 2>&1; then
  printf 'GNU Stow is required.\n' >&2
  printf 'macOS: brew install stow\n' >&2
  printf 'Linux: install the "stow" package with your package manager.\n' >&2
  exit 1
fi

case "$(uname -s)" in
  Darwin) platform=macos ;;
  Linux) platform=linux ;;
  *)
    printf 'Unsupported operating system: %s\n' "$(uname -s)" >&2
    exit 1
    ;;
esac

stow --dir="$repo_dir" --target="$HOME" --restow --no-folding common "$platform"
