{
    "layer": "top",
    "position": "top",
    "margin-top": 7,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces", "cpu", "memory"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/notification", "backlight", "idle_inhibitor", "pulseaudio", "network", "battery"],

    "hyprland/workspaces": {
        "active-only": false,
        "all-outputs": false,
        "format": "{name}",
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5]
        }
    },

    "hyprland/window": {
        "max-length": 25,
        "tooltip": false
    },

    // Left modules
    "cpu": {
        "interval": 10,
        "format": "´Æ╝  {usage}%",
        "max-length": 10,
        "on-click": "kitty -e 'htop'"
    },

    "memory": {
        "interval": 30,
        "format": "¯┐à  {used:0.2f}GB",
        "max-length": 10,
        "tooltip": false,
        "warning": 70,
        "critical": 90
    },

    // Center modules
    "clock": {
        "interval": 1,
        "locale": "C",
        "timezone": "America/Caracas",
        "format": "´ü│ {:%a %d | %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-scroll-up": "tz_up",
            "on-scroll-down": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        },
    },

    // Right modules
    "tray": {
        "icon-size": 15
    },

    "custom/notification": {
        "tooltip": true,
        "format": "{icon}",
        "format-icons": {
            "notification": "¾▒à½",
            "none": "¾░é£",
            "dnd-notification": "¾░éá",
            "dnd-none": "¾░¬ô",
            "inhibited-notification": "¾░éø",
            "inhibited-none": "¾░¬æ",
            "dnd-inhibited-notification": "¾░éø",
            "dnd-inhibited-none": "¾░¬æ"
        },
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["ÔİÇ´©Å", "´åà"],
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons":{
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },

    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{icon}´èö {volume}% {format_source}",
      "format-bluetooth-muted": "´æĞ {format_source}",
      "format-muted": "´æĞ   {format_source}",
      "format-icons": {
        "headphone": "´ÇÑ",
        "hands-free": "´ûÉ",
        "headset": "­şÄğ",
        "phone": "´éò",
        "portable": "´éò",
        "car": "´å╣",
        "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
      },
      "on-click": "pavucontrol"
    },

    "network": {
        "format": "{icon}",
        "format-wifi": "{icon} {signalStrength}%",
        "format-icons": {
            "wifi": ["¾░ñş", "¾░ñó" ,"¾░ñ¿"],
            "ethernet": ["´ø┐"],
            "disconnected": ["¾░û¬"]
        },
        "on-click": "kitty -e nmtui",
        "tooltip-format": "{essid}",
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "ÔÜí  {capacity}%",
        "format-plugged": "´çĞ  {capacity}%",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
}
